# ============================================================
# OpenClaw – MrSurety QA Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit the filled-in .env file – it is in .gitignore.
# ============================================================

# ── MrSurety App ────────────────────────────────────────────
# Live app URL (Vercel deployment)
MRSURETY_BASE_URL=https://frontend-tan-five-46.vercel.app

# Admin credentials (provided by Christopher for QA testing only)
# ⚠️  Do not share outside the QA team. Do not use in production.
# ⚠️  Rotate immediately if this file is ever exposed.
ADMIN_EMAIL=admin@mrsurety.com
ADMIN_PASSWORD=MrSurety2026!

# ── Test User Accounts ─────────────────────────────────────────────────────
# These are the accounts the script creates on the live app via:
#   python3 mrsurety_qa.py --workflow create-accounts
#
# ✅ You can use ANY email service for these accounts:
#      Outlook.com / Hotmail / Live  ← email screenshots auto-supported
#      Gmail (gmail.com)             ← email screenshots auto-supported
#      Yahoo Mail (yahoo.com)        ← email screenshots auto-supported
#      Any other provider            ← you can log in manually to verify emails
#
# The defaults below use Outlook.com. Change them to match your actual inboxes.
# All accounts share the same password for simplicity.

# Agent accounts
AGENT_EMAIL=agent.test1@outlook.com
AGENT_PASSWORD=QAtest@2026!
AGENT2_EMAIL=agent.test2@outlook.com
AGENT2_PASSWORD=QAtest@2026!

# Homeowner accounts (3 variants)
HOMEOWNER_EMAIL_A=homeowner.test2@outlook.com      # Method A – referral link
HOMEOWNER_PASSWORD_A=QAtest@2026!
HOMEOWNER_ADDRESS_A=456 Oak Ave, Anaheim CA 92801
HOMEOWNER_PERMIT_TYPE_A=plumbing

HOMEOWNER_EMAIL_B=homeowner.test1@outlook.com      # Method B – agent email entry
HOMEOWNER_PASSWORD_B=QAtest@2026!
HOMEOWNER_ADDRESS_B=123 Main St, Los Angeles CA 90001
HOMEOWNER_PERMIT_TYPE_B=electrical

HOMEOWNER_EMAIL_C=homeowner.test3@outlook.com      # Edge case – no agent
HOMEOWNER_PASSWORD_C=QAtest@2026!

# Contractor accounts
CONTRACTOR_EMAIL=contractor.test1@outlook.com
CONTRACTOR_PASSWORD=QAtest@2026!
CONTRACTOR2_EMAIL=contractor.test2@outlook.com
CONTRACTOR2_PASSWORD=QAtest@2026!

# Technician account
TECH_EMAIL=tech.test1@outlook.com
TECH_PASSWORD=QAtest@2026!

# Insurance agent (no app account – receives secure upload link via email)
INSURANCE_AGENT_EMAIL=ins.agent.test@outlook.com

# ── Agent Upload Invite – Secure Links (set after Workflow 9 generates them) ──
# Full secure upload URL extracted from the invite email received by the insurance agent
AGENT_UPLOAD_LINK=https://frontend-tan-five-46.vercel.app/agent-upload/<token-from-invite-email>
# A previously-revoked upload URL for security testing
REVOKED_UPLOAD_LINK=https://frontend-tan-five-46.vercel.app/agent-upload/<revoked-token>
# An upload URL that is more than 7 days old (expired)
EXPIRED_UPLOAD_LINK=https://frontend-tan-five-46.vercel.app/agent-upload/<expired-token>
# A manipulated URL attempting access to a different contractor
MANIPULATED_UPLOAD_LINK=https://frontend-tan-five-46.vercel.app/agent-upload/<other-contractor-token>

# ── Stripe Test Payments ─────────────────────────────────────
# These are Stripe TEST mode values – safe to commit; never use real card numbers
STRIPE_TEST_CARD=4242424242424242
STRIPE_TEST_EXPIRY=1229
STRIPE_TEST_CVV=123
STRIPE_TEST_ZIP=90210

# ── Email Inbox Credentials (for the email screenshot workflow) ───────────────
# The email-docusign workflow logs into these inboxes to screenshot every email.
# It auto-detects the provider (Outlook, Gmail, Yahoo) from the email address.
# These default to the same addresses as the test user accounts above.
OUTLOOK_AGENT_EMAIL=agent.test1@outlook.com
OUTLOOK_AGENT_PASSWORD=QAtest@2026!
OUTLOOK_HOMEOWNER_A_EMAIL=homeowner.test2@outlook.com
OUTLOOK_HOMEOWNER_A_PASSWORD=QAtest@2026!
OUTLOOK_HOMEOWNER_B_EMAIL=homeowner.test1@outlook.com
OUTLOOK_HOMEOWNER_B_PASSWORD=QAtest@2026!
OUTLOOK_CONTRACTOR_EMAIL=contractor.test1@outlook.com
OUTLOOK_CONTRACTOR_PASSWORD=QAtest@2026!

# ── Chat Interface – Telegram (optional) ────────────────────
# Create a bot at https://t.me/BotFather and paste the token here
TELEGRAM_BOT_TOKEN=
# Your personal Telegram Chat ID (send /start to your bot, then check the API)
TELEGRAM_CHAT_ID=

# ── Chat Interface – Slack (optional) ───────────────────────
SLACK_BOT_TOKEN=
SLACK_CHANNEL=#mrsurety-qa

# ── Google Drive Upload (optional) ──────────────────────────
# The folder ID from the shared Google Drive URL Christopher provided
# e.g. https://drive.google.com/drive/folders/<FOLDER_ID>
GDRIVE_FOLDER_ID=
# Path to a Google service-account JSON key file for auto-upload.
# Steps to create one:
#   1. Go to console.cloud.google.com → IAM & Admin → Service Accounts
#   2. Create a service account, then Keys → Add Key → JSON → save the file
#   3. Share the Drive folder with the service-account email address,
#      granting it "Editor" permission (minimum required to upload files)
#   4. Set this var to the local path of the downloaded JSON file
# Note: mrsurety_qa.py uses the 'drive.file' scope, so the service account
# can only access files it creates — not the rest of your Google Drive.
GDRIVE_SERVICE_ACCOUNT_JSON=

# ── OpenClaw Browser Settings ───────────────────────────────
OPENCLAW_HEADLESS=false
OPENCLAW_VIEWPORT_WIDTH=1920
OPENCLAW_VIEWPORT_HEIGHT=1080
OPENCLAW_SLOW_MO=50
OPENCLAW_TIMEOUT=120000
# Webmail login timeout (ms) – Outlook/Gmail/Yahoo are slow. Default: 180 seconds.
OPENCLAW_WEBMAIL_TIMEOUT=180000

# ── Output Paths ─────────────────────────────────────────────
OPENCLAW_SCREENSHOT_PATH=./output/screenshots
OPENCLAW_VIDEO_PATH=./output/videos
OPENCLAW_DATA_PATH=./output/data
OPENCLAW_REPORT_PATH=./output/reports
