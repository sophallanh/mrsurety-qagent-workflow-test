# ============================================================
# OpenClaw – MrSurety QA Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit the filled-in .env file – it is in .gitignore.
# ============================================================

# ── MrSurety App ────────────────────────────────────────────
# Base URL for the staging or production app
MRSURETY_BASE_URL=https://staging.mrsurety.com

# Admin credentials (provided by Christopher for QA testing only)
# ⚠️  Do not share outside the QA team. Do not use in production.
# ⚠️  Rotate immediately if this file is ever exposed.
ADMIN_EMAIL=admin@mrsurety.com
ADMIN_PASSWORD=MrSurety2026!

# ── Test User Accounts (created by workflows; fill in after Workflow 2–4) ──
# Agent test account (created in Workflow 2)
AGENT_EMAIL=testagent_YYYYMMDD@outlook.com
AGENT_PASSWORD=MrSuretyQA2026!
AGENT_NAME_FIRST=Test
AGENT_NAME_LAST=Agent

# Homeowner test account – Method A (referral link; created in Workflow 3)
HOMEOWNER_EMAIL_A=testhomeowner_a_YYYYMMDD@outlook.com
HOMEOWNER_PASSWORD_A=MrSuretyQA2026!
HOMEOWNER_ADDRESS_A=123 Main St, Los Angeles CA 90001
HOMEOWNER_PERMIT_TYPE_A=plumbing

# Homeowner test account – Method B (agent email entry; created in Workflow 3)
HOMEOWNER_EMAIL_B=testhomeowner_b_YYYYMMDD@outlook.com
HOMEOWNER_PASSWORD_B=MrSuretyQA2026!
HOMEOWNER_ADDRESS_B=456 Oak Ave, Anaheim CA 92801
HOMEOWNER_PERMIT_TYPE_B=electrical

# Contractor test account (created in Workflow 5)
CONTRACTOR_EMAIL=testcontractor_YYYYMMDD@outlook.com
CONTRACTOR_PASSWORD=MrSuretyQA2026!
CONTRACTOR_COMPANY=Test Contractor LLC

# Insurance agent (no app login – receives upload link via email; Workflow 5)
INSURANCE_AGENT_EMAIL=testinsagent_YYYYMMDD@outlook.com

# ── Agent Upload Invite – Secure Links (set after Workflow 5 generates them) ──
# Full secure upload URL extracted from the invite email
AGENT_UPLOAD_LINK=https://staging.mrsurety.com/agent-upload/<token-from-invite-email>
# A previously-revoked upload URL for security testing
REVOKED_UPLOAD_LINK=https://staging.mrsurety.com/agent-upload/<revoked-token>
# An upload URL that is more than 7 days old (expired)
EXPIRED_UPLOAD_LINK=https://staging.mrsurety.com/agent-upload/<expired-token>
# A manipulated URL attempting access to a different contractor
MANIPULATED_UPLOAD_LINK=https://staging.mrsurety.com/agent-upload/<other-contractor-token>

# ── Stripe Test Payments ─────────────────────────────────────
# These are Stripe TEST mode values – safe to commit; never use real card numbers
STRIPE_TEST_CARD=4242424242424242
STRIPE_TEST_EXPIRY=1229
STRIPE_TEST_CVV=123
STRIPE_TEST_ZIP=90210

# ── Email / Outlook Inbox Credentials ───────────────────────
# Outlook credentials for reading test inboxes during Workflow 4
OUTLOOK_AGENT_EMAIL=testagent_YYYYMMDD@outlook.com
OUTLOOK_AGENT_PASSWORD=MrSuretyQA2026!
OUTLOOK_HOMEOWNER_A_EMAIL=testhomeowner_a_YYYYMMDD@outlook.com
OUTLOOK_HOMEOWNER_A_PASSWORD=MrSuretyQA2026!
OUTLOOK_HOMEOWNER_B_EMAIL=testhomeowner_b_YYYYMMDD@outlook.com
OUTLOOK_HOMEOWNER_B_PASSWORD=MrSuretyQA2026!
OUTLOOK_CONTRACTOR_EMAIL=testcontractor_YYYYMMDD@outlook.com
OUTLOOK_CONTRACTOR_PASSWORD=MrSuretyQA2026!

# ── Chat Interface – Telegram (optional) ────────────────────
# Create a bot at https://t.me/BotFather and paste the token here
TELEGRAM_BOT_TOKEN=
# Your personal Telegram Chat ID (send /start to your bot, then check the API)
TELEGRAM_CHAT_ID=

# ── Chat Interface – Slack (optional) ───────────────────────
SLACK_BOT_TOKEN=
SLACK_CHANNEL=#mrsurety-qa

# ── Google Drive Upload (optional) ──────────────────────────
# The folder ID from the shared Google Drive URL Christopher provided
# e.g. https://drive.google.com/drive/folders/<FOLDER_ID>
GDRIVE_FOLDER_ID=

# ── OpenClaw Browser Settings ───────────────────────────────
OPENCLAW_HEADLESS=false
OPENCLAW_VIEWPORT_WIDTH=1920
OPENCLAW_VIEWPORT_HEIGHT=1080
OPENCLAW_SLOW_MO=50
OPENCLAW_TIMEOUT=60000

# ── Output Paths ─────────────────────────────────────────────
OPENCLAW_SCREENSHOT_PATH=./output/screenshots
OPENCLAW_VIDEO_PATH=./output/videos
OPENCLAW_DATA_PATH=./output/data
OPENCLAW_REPORT_PATH=./output/reports
